METRICS_WINDOW_SIZE=500
SEARCH_CANDIDATE_MULTIPLIER=8
SEARCH_CANDIDATE_CAP=500
SEARCH_HNSW_EF_SEARCH=80
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
