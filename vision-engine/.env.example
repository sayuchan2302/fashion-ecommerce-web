IMAGE_SEARCH_PRODUCT_CATEGORY_MATCH_BOOST=0.02
IMAGE_SEARCH_PRODUCT_IN_STOCK_BOOST=0.04
IMAGE_SEARCH_CATEGORY_FILTER_MODE=hard
